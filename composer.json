{
    "name": "vlinde/helper",
    "description": ":package_description",
    "license": "license",
    "authors": [
        {
            "name": "author name",
            "email": "author email",
            "homepage": "author homepage"
        }
    ],
    "homepage": "https://github.com/vlinde/helper",
    "keywords": ["Laravel", "helper"],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "giggsey/libphonenumber-for-php": "^8.12.51|^9.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Vlinde\\Helper\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vlinde\\Helper\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vlinde\\Helper\\HelperServiceProvider"
            ],
            "aliases": {
                "helper": "Vlinde\\Helper\\Facades\\Helper"
            }
        }
    }
}
